// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User model for persistent accounts
model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  passwordHash String?  // null for guest users
  role         UserRole @default(GUEST)
  isActive     Boolean  @default(true)
  
  // Profile information
  firstName    String?
  lastName     String?
  avatar       String?
  bio          String?
  
  // Notification preferences
  emailNotifications Boolean @default(true)
  pushNotifications  Boolean @default(true)
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastLoginAt DateTime?
  
  // Relations
  wallets            Wallet[]
  userAirdropStatuses UserAirdropStatus[]
  sessions           Session[]
  
  @@map("users")
}

// Wallet model to link wallets to users
model Wallet {
  id        String   @id @default(cuid())
  address   String   @unique // Ethereum wallet address
  chainId   Int      @default(1) // Ethereum mainnet by default
  isPrimary Boolean  @default(false)
  
  // Wallet metadata
  ensName     String?
  ensAvatar   String?
  lastConnectedAt DateTime @default(now())
  
  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("wallets")
}

// Airdrop model for vetted airdrop information
model Airdrop {
  id          String        @id @default(cuid())
  name        String
  description String
  logoUrl     String?
  websiteUrl  String?
  
  // Airdrop details
  status      AirdropStatus @default(PENDING)
  category    String        // e.g., "DeFi", "Gaming", "NFT", "Layer 2"
  blockchain  String        // e.g., "Ethereum", "Polygon", "BSC"
  
  // Requirements and eligibility
  requirements Json // Array of requirement objects
  eligibility  Json // Eligibility criteria
  
  // Risk assessment
  riskScore    Int  @default(0) // 0-100 risk score
  riskLevel    RiskLevel @default(LOW)
  
  // Timeline
  startDate    DateTime?
  endDate      DateTime?
  
  // Vesting and token info
  totalSupply  String?
  tokenSymbol  String?
  vestingPeriod String? // e.g., "3 months", "6 months"
  
  // Social links
  twitterHandle String?
  discordInvite String?
  telegramGroup String?
  
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  userAirdropStatuses UserAirdropStatus[]
  vettingReports     VettingReport[]
  discoveredAirdrops DiscoveredAirdrop[]
  
  @@map("airdrops")
}

// User's interaction status with an airdrop
model UserAirdropStatus {
  id        String              @id @default(cuid())
  status    UserAirdropStatusType @default(NOT_STARTED)
  notes     String?             // User's private notes
  
  // Progress tracking
  completedRequirements Json? // Array of completed requirement IDs
  progressPercentage    Float  @default(0)
  
  // Important dates
  startedAt   DateTime?
  completedAt DateTime?
  
  // Relations
  userId     String
  airdropId  String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  airdrop    Airdrop  @relation(fields: [airdropId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([userId, airdropId])
  @@map("user_airdrop_statuses")
}

// Vetting reports for airdrop analysis
model VettingReport {
  id     String       @id @default(cuid())
  layer  VettingLayer // Security, Tokenomics, Team, etc.
  result VettingResult
  
  // Report data
  data   Json // Detailed analysis data
  score  Int  // Score for this layer (0-100)
  
  // AI-generated insights
  summary String?
  risks   String   // JSON string array of identified risks
  rewards String   // JSON string array of potential rewards
  
  // Metadata
  generatedAt DateTime @default(now())
  model       String?  // AI model used for analysis
  
  // Relations
  airdropId String
  airdrop  Airdrop @relation(fields: [airdropId], references: [id], onDelete: Cascade)
  
  @@map("vetting_reports")
}

// Discovery sources for tracking where airdrops were found
model DiscoverySource {
  id          String        @id @default(cuid())
  name        String        // e.g., "Twitter/X", "Project Website", "Discord"
  type        SourceType
  url         String?       // Source URL if applicable
  isActive    Boolean       @default(true)
  
  // Configuration
  config      Json?         // Scraper configuration
  lastScraped DateTime?
  
  // Relations
  discoveredAirdrops DiscoveredAirdrop[]
  
  @@map("discovery_sources")
}

// Discovered airdrops before vetting
model DiscoveredAirdrop {
  id          String              @id @default(cuid())
  name        String
  description String?
  url         String?             // Source URL where it was found
  rawContent  Json?               // Raw scraped data
  
  // Status tracking
  status      DiscoveryStatus     @default(DISCOVERED)
  priority    DiscoveryPriority   @default(MEDIUM)
  
  // Duplicate detection
  hash        String?             // Content hash for duplicate detection
  duplicateOf String?             // Reference to original discovered airdrop
  
  // Metadata
  discoveredAt DateTime @default(now())
  
  // Relations
  sourceId            String
  source              DiscoverySource @relation(fields: [sourceId], references: [id])
  airdropId           String?
  airdrop             Airdrop?        @relation(fields: [airdropId], references: [id])
  vettingJobs         VettingJob[]
  
  @@map("discovered_airdrops")
}

// Background jobs for vetting process
model VettingJob {
  id          String        @id @default(cuid())
  type        JobType
  status      JobStatus     @default(PENDING)
  priority    Int           @default(5)
  
  // Job configuration
  config      Json          // Job parameters
  result      Json?         // Job results
  
  // Progress tracking
  progress    Float         @default(0)
  currentStep String?
  totalSteps  Int?
  
  // Error handling
  error       String?
  retryCount  Int           @default(0)
  maxRetries  Int           @default(3)
  
  // Timestamps
  scheduledAt DateTime      @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  // Relations
  discoveredAirdropId String
  discoveredAirdrop   DiscoveredAirdrop @relation(fields: [discoveredAirdropId], references: [id], onDelete: Cascade)
  
  @@map("vetting_jobs")
}

// External API data cache
model ExternalData {
  id        String      @id @default(cuid())
  source    String      // e.g., "goplus", "moralis", "coingecko"
  type      DataType    // e.g., "contract_analysis", "token_price", "social_stats"
  identifier String     // Contract address, token symbol, etc.
  data      Json        // Cached API response
  
  // Cache management
  expiresAt DateTime
  isValid   Boolean     @default(true)
  
  // Metadata
  fetchedAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  
  @@unique([source, type, identifier])
  @@map("external_data")
}

// Session management for JWT tokens
model Session {
  id           String    @id @default(cuid())
  token        String    @unique // JWT token hash
  refreshToken String?   @unique // Refresh token
  userAgent    String?
  ipAddress    String?
  
  // Session status
  isActive     Boolean   @default(true)
  expiresAt    DateTime
  
  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("sessions")
}

// Enums
enum UserRole {
  GUEST
  USER
  PREMIUM
  ADMIN
}

enum AirdropStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  SUSPENDED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum UserAirdropStatusType {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  FAILED
  CLAIMED
}

enum VettingLayer {
  SECURITY
  TOKENOMICS
  TEAM
  COMMUNITY
  TECHNICAL
  LEGAL
}

enum VettingResult {
  SAFE
  CAUTION
  RISKY
  SCAM
}

enum SourceType {
  TWITTER
  DISCORD
  TELEGRAM
  WEBSITE
  REDDIT
  MEDIUM
  YOUTUBE
  CUSTOM
}

enum DiscoveryStatus {
  DISCOVERED
  PROCESSING
  VETTING
  APPROVED
  REJECTED
  DUPLICATE
}

enum DiscoveryPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum JobType {
  SCRAPE_TWITTER
  SCRAPE_WEBSITE
  VETTING_SANITY
  VETTING_FUNDAMENTALS
  VETTING_AI_ANALYSIS
  EXTERNAL_API_CALL
  NOTIFICATION
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  RETRYING
}

enum DataType {
  CONTRACT_ANALYSIS
  TOKEN_PRICE
  SOCIAL_STATS
  TEAM_INFO
  TECHNICAL_AUDIT
  MARKET_DATA
}