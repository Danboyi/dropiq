{
  "name": "dropiq",
  "version": "0.1.0",
  "private": true,
  "description": "DropIQ - A comprehensive fullstack application built with Nx monorepo",
  "scripts": {
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky install",
    "dev:frontend": "nx serve frontend",
    "dev:backend": "nx serve backend",
    "dev:docs": "nx serve docs",
    "build:frontend": "nx build frontend",
    "build:backend": "nx build backend",
    "build:docs": "nx build docs",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "devDependencies": {
    "@nx/eslint": "^19.8.4",
    "@nx/eslint-plugin": "^19.8.4",
    "@nx/jest": "^19.8.4",
    "@nx/js": "^19.8.4",
    "@nx/next": "^19.8.4",
    "@nx/node": "^19.8.4",
    "@nx/webpack": "^19.8.4",
    "@nx/workspace": "^19.8.4",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/jest": "^29.5.12",
    "@types/node": "18.16.9",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "~8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "~2.29.0",
    "eslint-plugin-jsx-a11y": "~6.9.0",
    "eslint-plugin-react": "~7.34.0",
    "eslint-plugin-react-hooks": "~5.0.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "lint-staged": "^15.2.7",
    "nx": "^19.8.4",
    "prettier": "^3.3.2",
    "ts-jest": "^29.1.2",
    "tslib": "^2.6.3",
    "typescript": "~5.5.3"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tslib": "^2.6.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}